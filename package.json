{
  "name": "faker-cli",
  "version": "0.2.1",
  "type": "module",
  "bin": {
    "faker": "./src/cli.ts"
  },
  "scripts": {
    "test": "bun test",
    "build": "bun run build:darwin-arm64 && bun run build:darwin-x64 && bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:windows-x64",
    "build:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 src/cli.ts --outfile dist/faker-darwin-arm64",
    "build:darwin-x64": "bun build --compile --target=bun-darwin-x64 src/cli.ts --outfile dist/faker-darwin-x64",
    "build:linux-x64": "bun build --compile --target=bun-linux-x64 src/cli.ts --outfile dist/faker-linux-x64",
    "build:linux-arm64": "bun build --compile --target=bun-linux-arm64 src/cli.ts --outfile dist/faker-linux-arm64",
    "build:windows-x64": "bun build --compile --target=bun-windows-x64 src/cli.ts --outfile dist/faker-windows-x64.exe",
    "generate-fixtures": "bun run test/fixtures/generate.ts",
    "generate-metadata": "bun run test/fixtures/generate-metadata.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "vitepress": "^1.6.4",
    "vue": "^3.5.31"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  }
}
